{
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "src",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "__tests__",
    "e2e"
  ],
  "extends": "./tsconfig.json",
  "include": ["src"],
  "references": [
    {
      "path": "../../libs/sdk/tsconfig.lib.json"
    },
    {
      "path": "../../libs/crypto-service/tsconfig.lib.json"
    }
  ]
}
