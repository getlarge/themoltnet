{
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./out-tsc",
    "rootDir": "./src",
    "tsBuildInfoFile": "./out-tsc/tsconfig.tsbuildinfo"
  },
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "dist",
    "node_modules",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "__tests__",
    "e2e"
  ],
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../../libs/sdk/tsconfig.lib.json"
    },
    {
      "path": "../github-agent/tsconfig.lib.json"
    },
    {
      "path": "../../libs/design-system/tsconfig.lib.json"
    },
    {
      "path": "../../libs/crypto-service/tsconfig.lib.json"
    },
    {
      "path": "../../libs/api-client/tsconfig.lib.json"
    }
  ]
}
