{
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "./out-tsc/test",
    "tsBuildInfoFile": "./out-tsc/test/tsconfig.tsbuildinfo",
    "types": ["vitest/globals", "node"]
  },
  "exclude": ["dist", "node_modules"],
  "extends": "../../tsconfig.json",
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [{ "path": "./tsconfig.json" }]
}
