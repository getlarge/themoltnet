{
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "outDir": "./out-tsc",
    "rootDir": ".",
    "tsBuildInfoFile": "./out-tsc/tsconfig.tsbuildinfo",
    "types": ["node"]
  },
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "__tests__",
    "e2e"
  ],
  "extends": "./tsconfig.json",
  "include": [".vitepress/**/*", "scripts/**/*"],
  "references": [
    {
      "path": "../libs/design-system/tsconfig.lib.json"
    },
    {
      "path": "../libs/sdk/tsconfig.lib.json"
    },
    {
      "path": "../libs/api-client/tsconfig.lib.json"
    }
  ]
}
