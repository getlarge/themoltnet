{
  "account_experience": {
    "favicon_dark_url": "${CONSOLE_BASE_URL}/favicon.svg",
    "favicon_light_url": "${CONSOLE_BASE_URL}/favicon.svg",
    "logo_dark_url": "${CONSOLE_BASE_URL}/favicon.svg",
    "logo_light_url": "${CONSOLE_BASE_URL}/favicon.svg"
  },
  "cors_admin": {
    "enabled": true,
    "origins": ["${LANDING_BASE_URL}", "${API_BASE_URL}", "${CONSOLE_BASE_URL}"]
  },
  "cors_public": {
    "allow_credentials": true,
    "allowed_headers": ["Authorization", "Content-Type", "X-Requested-With"],
    "allowed_methods": ["POST", "GET", "PUT", "PATCH", "DELETE", "OPTIONS"],
    "enabled": true,
    "exposed_headers": ["Content-Type"],
    "max_age": 86400,
    "origins": ["${LANDING_BASE_URL}", "${API_BASE_URL}", "${CONSOLE_BASE_URL}"]
  },
  "name": "MoltNet",
  "services": {
    "identity": {
      "config": {
        "courier": {
          "smtp": {
            "connection_uri": "${SMTP_CONNECTION_URI}",
            "from_name": "MoltNet"
          }
        },
        "identity": {
          "default_schema_id": "moltnet_human",
          "schemas": [
            {
              "id": "moltnet_agent",
              "url": "base64://${IDENTITY_SCHEMA_AGENT_BASE64}"
            },
            {
              "id": "moltnet_human",
              "url": "base64://${IDENTITY_SCHEMA_HUMAN_BASE64}"
            }
          ]
        },
        "selfservice": {
          "allowed_return_urls": [
            "${LANDING_BASE_URL}/",
            "${API_BASE_URL}/",
            "${CONSOLE_BASE_URL}/"
          ],
          "default_browser_return_url": "${CONSOLE_BASE_URL}/",
          "flows": {
            "error": {
              "ui_url": "${CONSOLE_BASE_URL}/auth/error"
            },
            "login": {
              "after": {
                "oidc": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": false,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": false
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-login"
                      },
                      "hook": "web_hook"
                    }
                  ]
                },
                "password": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": false,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": false
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-login"
                      },
                      "hook": "web_hook"
                    }
                  ]
                }
              },
              "lifespan": "1h",
              "ui_url": "${CONSOLE_BASE_URL}/auth/login"
            },
            "logout": {
              "after": {
                "default_browser_return_url": "${CONSOLE_BASE_URL}/"
              }
            },
            "recovery": {
              "enabled": false
            },
            "registration": {
              "after": {
                "oidc": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": true,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": true
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-registration"
                      },
                      "hook": "web_hook"
                    },
                    {
                      "hook": "session"
                    }
                  ]
                },
                "password": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": true,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": true
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-registration"
                      },
                      "hook": "web_hook"
                    },
                    {
                      "hook": "session"
                    }
                  ]
                }
              },
              "enabled": true,
              "lifespan": "1h",
              "ui_url": "${CONSOLE_BASE_URL}/auth/registration"
            },
            "settings": {
              "after": {
                "profile": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": false,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": false
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-settings"
                      },
                      "hook": "web_hook"
                    }
                  ]
                }
              },
              "lifespan": "1h",
              "privileged_session_max_age": "15m",
              "ui_url": "${CONSOLE_BASE_URL}/auth/settings"
            },
            "verification": {
              "enabled": false
            }
          },
          "methods": {
            "code": {
              "config": {
                "lifespan": "15m"
              },
              "enabled": true
            },
            "link": {
              "enabled": false
            },
            "oidc": {
              "config": {
                "providers": [
                  {
                    "client_id": "${SELFSERVICE_OIDC_GITHUB_CLIENT_ID}",
                    "client_secret": "${SELFSERVICE_OIDC_GITHUB_CLIENT_SECRET}",
                    "id": "github",
                    "label": "GitHub",
                    "mapper_url": "base64://bG9jYWwgY2xhaW1zID0gc3RkLmV4dFZhcignY2xhaW1zJyk7CnsKICBpZGVudGl0eTogewogICAgdHJhaXRzOiB7CiAgICAgIHVzZXJuYW1lOiBjbGFpbXMubmlja25hbWUsCiAgICB9ICsgKGlmICdlbWFpbCcgaW4gY2xhaW1zICYmIGNsYWltcy5lbWFpbF92ZXJpZmllZCB0aGVuIHsgZW1haWw6IGNsYWltcy5lbWFpbCB9IGVsc2Uge30pLAogIH0sCn0K",
                    "provider": "github",
                    "scope": ["user:email"]
                  }
                ]
              },
              "enabled": true
            },
            "password": {
              "config": {
                "haveibeenpwned_enabled": true,
                "identifier_similarity_check_enabled": false,
                "min_password_length": 16
              },
              "enabled": true
            }
          }
        },
        "session": {
          "cookie": {
            "domain": ".${BASE_DOMAIN}",
            "http_only": true,
            "same_site": "Lax",
            "secure": true
          },
          "lifespan": "720h"
        }
      }
    },
    "oauth2": {
      "config": {
        "oauth2": {
          "client_credentials": {
            "default_grant_allowed_scope": false
          },
          "grant": {
            "jwt": {
              "iat_optional": false,
              "jti_optional": false,
              "max_ttl": "2h"
            }
          },
          "pkce": {
            "enforced": true,
            "enforced_for_public_clients": true
          }
        },
        "oidc": {
          "dynamic_client_registration": {
            "default_scope": [
              "diary:read",
              "diary:write",
              "crypto:sign",
              "agent:profile",
              "human:profile",
              "team:read"
            ],
            "enabled": true
          },
          "subject_identifiers": {
            "pairwise": {
              "salt": "${OIDC_PAIRWISE_SALT}"
            },
            "supported_types": ["public"]
          }
        },
        "token_hook": {
          "auth": {
            "config": {
              "in": "header",
              "name": "X-Ory-Api-Key",
              "value": "${ORY_ACTION_API_KEY}"
            },
            "type": "api_key"
          },
          "url": "${API_BASE_URL}/hooks/hydra/token-exchange"
        },
        "ttl": {
          "access_token": "1h",
          "auth_code": "10m",
          "id_token": "1h",
          "login_consent_request": "30m",
          "refresh_token": "720h"
        },
        "urls": {
          "error": "${CONSOLE_BASE_URL}/auth/error",
          "post_logout_redirect": "${CONSOLE_BASE_URL}/",
          "self": {
            "issuer": "${LANDING_BASE_URL}/"
          }
        }
      }
    },
    "permission": {
      "config": {}
    }
  }
}
