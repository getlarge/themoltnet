{
  "cors_public": {
    "allowed_headers": [
      "Authorization",
      "Content-Type",
      "X-Session-Token",
      "X-CSRF-Token",
      "Cookie"
    ],
    "enabled": true,
    "exposed_headers": ["Content-Type"],
    "origins": [
      "${LANDING_BASE_URL}",
      "${CONSOLE_BASE_URL}",
      "${ORY_PROJECT_URL}"
    ]
  },
  "name": "MoltNet",
  "services": {
    "account_experience": {
      "config": {
        "default_locale": "en",
        "enabled": true,
        "enabled_locales": [
          "en",
          "de",
          "es",
          "fr",
          "it",
          "ja",
          "nl",
          "pt",
          "ru",
          "zh"
        ],
        "favicon_dark_url": "https://storage.googleapis.com/bac-gcs-production/f52fd20549615bb3ab067924479b5dd9b699588922e417d34ed10b373aee1a4f2bab09c245b5ec03fea02fa73ced98a03c69a0a94d9ce97afd709328b550d3aa.svg",
        "favicon_light_url": "https://storage.googleapis.com/bac-gcs-production/f52fd20549615bb3ab067924479b5dd9b699588922e417d34ed10b373aee1a4f2bab09c245b5ec03fea02fa73ced98a03c69a0a94d9ce97afd709328b550d3aa.svg",
        "locale_behavior": "respect_accept_language",
        "logo_dark_url": "https://storage.googleapis.com/bac-gcs-production/f52fd20549615bb3ab067924479b5dd9b699588922e417d34ed10b373aee1a4f2bab09c245b5ec03fea02fa73ced98a03c69a0a94d9ce97afd709328b550d3aa.svg",
        "logo_light_url": "https://storage.googleapis.com/bac-gcs-production/f52fd20549615bb3ab067924479b5dd9b699588922e417d34ed10b373aee1a4f2bab09c245b5ec03fea02fa73ced98a03c69a0a94d9ce97afd709328b550d3aa.svg",
        "theme_variables_dark": {
          "brand_100": "#0f3d3a",
          "brand_200": "#145651",
          "brand_300": "#1e7a74",
          "brand_400": "#00b0a6",
          "brand_50": "#0d2e2c",
          "brand_500": "#00d4c8",
          "brand_600": "#33ded4",
          "brand_700": "#66e7df",
          "brand_800": "#99f0ea",
          "brand_900": "#ccf8f5",
          "brand_950": "#e6fbf9",
          "interface_background_default_disabled": "#1c1c2e",
          "interface_background_default_inverted": "#e8e8f0",
          "interface_background_default_primary": "#0f0f17",
          "interface_background_default_secondary": "#161622",
          "interface_background_default_tertiary": "#1c1c2e",
          "interface_border_default_inverted": "#e8e8f0",
          "interface_border_default_primary": "#2a2a3e",
          "interface_border_default_secondary": "#1c1c2e",
          "interface_foreground_brand_on_primary": "#000000",
          "interface_foreground_default_disabled": "#4a4a60",
          "interface_foreground_default_inverted": "#08080d",
          "interface_foreground_default_primary": "#e8e8f0",
          "interface_foreground_default_secondary": "#a0a0b8",
          "interface_foreground_default_tertiary": "#6b6b85"
        },
        "theme_variables_light": {
          "brand_100": "#cafbf5",
          "brand_200": "#92f6ed",
          "brand_300": "#3becdf",
          "brand_400": "#00d5c8",
          "brand_50": "#f0fdfb",
          "brand_500": "#00d4c8",
          "brand_600": "#00968d",
          "brand_700": "#007870",
          "brand_800": "#005f59",
          "brand_900": "#0b4f4a",
          "brand_950": "#032f2c",
          "interface_foreground_brand_on_primary": "#000000"
        },
        "translations": {}
      }
    },
    "identity": {
      "config": {
        "cookies": {
          "same_site": "Lax"
        },
        "courier": {
          "smtp": {
            "connection_uri": "${SMTP_CONNECTION_URI}",
            "from_address": "${SMTP_FROM_ADDRESS}",
            "from_name": "LeGreffier"
          }
        },
        "identity": {
          "default_schema_id": "moltnet_human",
          "schemas": [
            {
              "id": "moltnet_agent",
              "url": "base64://${IDENTITY_SCHEMA_AGENT_BASE64}"
            },
            {
              "id": "moltnet_human",
              "url": "base64://${IDENTITY_SCHEMA_HUMAN_BASE64}"
            }
          ]
        },
        "selfservice": {
          "allowed_return_urls": [
            "${LANDING_BASE_URL}/",
            "${API_BASE_URL}/",
            "${CONSOLE_BASE_URL}/",
            "${ORY_PROJECT_URL}/error",
            "${ORY_PROJECT_URL}/login",
            "${ORY_PROJECT_URL}/recovery",
            "${ORY_PROJECT_URL}/registration",
            "${ORY_PROJECT_URL}/settings",
            "${ORY_PROJECT_URL}/verification"
          ],
          "default_browser_return_url": "${CONSOLE_BASE_URL}/",
          "flows": {
            "error": {
              "ui_url": "/error"
            },
            "login": {
              "after": {
                "oidc": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": false,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": false
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-login"
                      },
                      "hook": "web_hook"
                    }
                  ]
                },
                "password": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": false,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": false
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-login"
                      },
                      "hook": "web_hook"
                    }
                  ]
                }
              },
              "lifespan": "1h",
              "ui_url": "/login"
            },
            "logout": {
              "after": {
                "default_browser_return_url": "${CONSOLE_BASE_URL}/"
              }
            },
            "recovery": {
              "enabled": true,
              "ui_url": "/recovery"
            },
            "registration": {
              "after": {
                "oidc": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": true,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": true
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-registration"
                      },
                      "hook": "web_hook"
                    },
                    {
                      "hook": "session"
                    }
                  ]
                },
                "password": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": true,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": true
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-registration"
                      },
                      "hook": "web_hook"
                    },
                    {
                      "hook": "session"
                    }
                  ]
                }
              },
              "enabled": true,
              "lifespan": "1h",
              "ui_url": "/registration"
            },
            "settings": {
              "after": {
                "profile": {
                  "hooks": [
                    {
                      "config": {
                        "auth": {
                          "config": {
                            "in": "header",
                            "name": "X-Ory-Api-Key",
                            "value": "${ORY_ACTION_API_KEY}"
                          },
                          "type": "api_key"
                        },
                        "body": "base64://ZnVuY3Rpb24oY3R4KSB7IGlkZW50aXR5OiBjdHguaWRlbnRpdHkgfQ==",
                        "can_interrupt": false,
                        "method": "POST",
                        "response": {
                          "ignore": false,
                          "parse": false
                        },
                        "url": "${API_BASE_URL}/hooks/kratos/after-settings"
                      },
                      "hook": "web_hook"
                    }
                  ]
                }
              },
              "lifespan": "1h",
              "privileged_session_max_age": "15m",
              "ui_url": "/settings"
            },
            "verification": {
              "enabled": true,
              "ui_url": "/verification"
            }
          },
          "methods": {
            "code": {
              "config": {
                "lifespan": "15m"
              },
              "enabled": true
            },
            "link": {
              "config": {
                "base_url": "${ORY_PROJECT_URL}/",
                "lifespan": "15m"
              },
              "enabled": false
            },
            "oidc": {
              "config": {
                "base_redirect_uri": "${ORY_PROJECT_URL}",
                "providers": [
                  {
                    "client_id": "${SELFSERVICE_OIDC_GITHUB_CLIENT_ID}",
                    "client_secret": "${SELFSERVICE_OIDC_GITHUB_CLIENT_SECRET}",
                    "id": "github",
                    "label": "GitHub",
                    "mapper_url": "base64://bG9jYWwgY2xhaW1zID0gc3RkLmV4dFZhcignY2xhaW1zJyk7CnsKICBpZGVudGl0eTogewogICAgdHJhaXRzOiB7CiAgICAgIHVzZXJuYW1lOiBjbGFpbXMubmlja25hbWUsCiAgICB9ICsgKGlmICdlbWFpbCcgaW4gY2xhaW1zICYmIGNsYWltcy5lbWFpbF92ZXJpZmllZCB0aGVuIHsgZW1haWw6IGNsYWltcy5lbWFpbCB9IGVsc2Uge30pLAogIH0sCn0K",
                    "provider": "github",
                    "scope": ["user:email"]
                  }
                ]
              },
              "enabled": true
            },
            "passkey": {
              "config": {
                "rp": {
                  "display_name": "MoltNet",
                  "id": "auth.${BASE_DOMAIN}",
                  "origins": ["${LANDING_BASE_URL}", "${CONSOLE_BASE_URL}"]
                }
              },
              "enabled": true
            },
            "password": {
              "config": {
                "haveibeenpwned_enabled": true,
                "identifier_similarity_check_enabled": false,
                "min_password_length": 16
              },
              "enabled": true
            },
            "profile": { "enabled": true },
            "saml": { "config": { "providers": [] }, "enabled": false },
            "totp": { "config": { "issuer": "MoltNet" }, "enabled": true }
          }
        },
        "session": {
          "cookie": {
            "http_only": true,
            "same_site": "Lax",
            "secure": true
          },
          "lifespan": "720h"
        }
      }
    },
    "oauth2": {
      "config": {
        "oauth2": {
          "client_credentials": {
            "default_grant_allowed_scope": false
          },
          "grant": {
            "jwt": {
              "iat_optional": false,
              "jti_optional": false,
              "max_ttl": "2h"
            }
          },
          "pkce": {
            "enforced": true,
            "enforced_for_public_clients": true
          }
        },
        "oidc": {
          "dynamic_client_registration": {
            "default_scope": [
              "diary:read",
              "diary:write",
              "crypto:sign",
              "agent:profile",
              "human:profile",
              "team:read"
            ],
            "enabled": true
          },
          "subject_identifiers": {
            "pairwise": {
              "salt": "${OIDC_PAIRWISE_SALT}"
            },
            "supported_types": ["public"]
          }
        },
        "strategies": {
          "access_token": "opaque",
          "jwt": {},
          "scope": "wildcard"
        },
        "token_hook": {
          "auth": {
            "config": {
              "in": "header",
              "name": "X-Ory-Api-Key",
              "value": "${ORY_ACTION_API_KEY}"
            },
            "type": "api_key"
          },
          "url": "${API_BASE_URL}/hooks/hydra/token-exchange"
        },
        "ttl": {
          "access_token": "1h",
          "auth_code": "10m",
          "id_token": "1h",
          "login_consent_request": "30m",
          "refresh_token": "720h"
        },
        "urls": {
          "consent": "${ORY_PROJECT_URL}/consent",
          "error": "${ORY_PROJECT_URL}/error",
          "login": "${ORY_PROJECT_URL}/login",
          "logout": "${ORY_PROJECT_URL}/logout",
          "post_logout_redirect": "${CONSOLE_BASE_URL}/",
          "registration": "${ORY_PROJECT_URL}/registration",
          "self": {
            "issuer": "${ORY_PROJECT_URL}"
          }
        }
      }
    },
    "permission": {
      "config": {}
    }
  }
}
