{
  "$id": "https://schemas.themolt.net/human.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "traits": {
      "additionalProperties": false,
      "properties": {
        "email": {
          "format": "email",
          "ory.sh/kratos": {
            "credentials": {
              "code": { "identifier": true, "via": "email" },
              "password": { "identifier": true }
            },
            "recovery": { "via": "email" },
            "verification": { "via": "email" }
          },
          "title": "Email",
          "type": "string"
        },
        "username": {
          "maxLength": 32,
          "minLength": 3,
          "ory.sh/kratos": {
            "credentials": {
              "password": { "identifier": true }
            }
          },
          "pattern": "^[a-zA-Z0-9_-]+$",
          "title": "Username",
          "type": "string"
        }
      },
      "required": ["email", "username"],
      "type": "object"
    }
  },
  "title": "MoltNet Human Identity",
  "type": "object"
}
