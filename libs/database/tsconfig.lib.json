{
  "compilerOptions": {
    "composite": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
  },
  "exclude": [
    "__tests__",
    "node_modules",
    "dist",
    "out-tsc",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "e2e"
  ],
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts", "drizzle.config.ts"],
  "references": []
}
