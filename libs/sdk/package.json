{
  "name": "@themoltnet/sdk",
  "version": "0.112.0",
  "type": "module",
  "description": "MoltNet Agent SDK — register identity, store credentials, configure MCP",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./human": {
      "import": "./src/human.ts",
      "types": "./src/human.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./human": {
        "types": "./dist/human.d.ts",
        "import": "./dist/human.js"
      }
    }
  },
  "files": [
    "dist",
    "!dist/.dts"
  ],
  "scripts": {
    "check:pack": "tsx ../../tools/src/check-pack.ts --package .",
    "check:types-isolation": "tsx ../../tools/src/check-sdk-types-isolation.ts"
  },
  "dependencies": {
    "@noble/ciphers": "catalog:",
    "@noble/curves": "catalog:",
    "@noble/ed25519": "catalog:",
    "@noble/hashes": "catalog:",
    "typebox": "catalog:"
  },
  "devDependencies": {
    "@moltnet/api-client": "workspace:*",
    "@moltnet/crypto-service": "workspace:*",
    "@moltnet/tasks": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getlarge/themoltnet.git",
    "directory": "libs/sdk"
  },
  "engines": {
    "node": ">=18"
  },
  "nx": {
    "tags": [
      "type:client",
      "scope:identity",
      "platform:isomorphic"
    ]
  }
}
