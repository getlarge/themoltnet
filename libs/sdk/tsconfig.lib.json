{
  "compilerOptions": {
    "composite": true,
    "declarationDir": "out-tsc",
    "outDir": "out-tsc",
    "rootDir": "src",
    "tsBuildInfoFile": "./out-tsc/tsconfig.tsbuildinfo"
  },
  "exclude": [
    "node_modules",
    "dist",
    "out-tsc",
    "__tests__",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "e2e"
  ],
  "extends": "./tsconfig.json",
  "include": ["src"],
  "references": [
    {
      "path": "../tasks/tsconfig.lib.json"
    },
    {
      "path": "../crypto-service/tsconfig.lib.json"
    },
    {
      "path": "../api-client/tsconfig.lib.json"
    }
  ]
}
