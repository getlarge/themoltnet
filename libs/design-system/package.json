  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./cli": {
      "import": "./src/cli/index.ts",
      "types": "./src/cli/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./cli": {
        "types": "./dist/cli/index.d.ts",
        "import": "./dist/cli/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "tsc --watch",
    "demo": "vite demo",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b --emitDeclarationOnly",
    "lint": "eslint .",
    "check:pack": "tsx ../../tools/src/check-pack.ts --package ."
  },
  "peerDependencies": {
    "figlet": ">=1.0.0",
    "ink": ">=5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
