    "figlet": {
      "optional": true
    },
    "ink": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "figlet": "^1.10.0",
    "ink": "^6.8.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
