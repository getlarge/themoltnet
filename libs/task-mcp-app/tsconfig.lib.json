{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "lib": ["ES2022", "DOM"],
    "outDir": "./out-tsc",
    "rootDir": "./src",
    "tsBuildInfoFile": "./out-tsc/tsconfig.tsbuildinfo",
    "types": ["node", "vite/client"]
  },
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "__tests__",
    "e2e"
  ],
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../design-system/tsconfig.lib.json"
    }
  ]
}
