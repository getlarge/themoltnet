    "composite": true,
    "lib": ["ES2022"],
    "outDir": "./out-tsc",
    "rootDir": "./src",
    "tsBuildInfoFile": "./out-tsc/tsconfig.tsbuildinfo",
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "src/**/*.spec.ts"],
  "extends": "./tsconfig.json",
  "include": ["src"],
  "references": [
    {
      "path": "../sdk/tsconfig.lib.json"
    },
    {
      "path": "../agent-runtime/tsconfig.lib.json"
    },
    {
      "path": "../crypto-service"
    }
  ]
}
