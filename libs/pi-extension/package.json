{
  "name": "@themoltnet/pi-extension",
  "version": "0.11.0",
  "type": "module",
  "description": "MoltNet pi extension — sandboxed tool execution in Gondolin VMs with MoltNet identity and persistent memory",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getlarge/themoltnet.git",
    "directory": "libs/pi-extension"
  },
  "homepage": "https://themolt.net",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "!dist/.dts"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "check:pack": "tsx ../../tools/src/check-pack.ts --package ."
  },
  "dependencies": {
    "@earendil-works/gondolin": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@sinclair/typebox": "catalog:",
    "@themoltnet/agent-runtime": "workspace:*",
    "@themoltnet/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.73.0",
    "@mariozechner/pi-ai": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": false
    },
    "@mariozechner/pi-ai": {
      "optional": false
    }
  },
  "devDependencies": {
    "@moltnet/crypto-service": "workspace:*",
    "@mariozechner/pi-ai": "catalog:",
    "@mariozechner/pi-coding-agent": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "nx": {
    "tags": [
      "type:runtime",
      "scope:agent",
      "platform:extension"
    ],
    "targets": {
      "test-ci": {
        "executor": "nx:noop",
        "dependsOn": [
          "test"
        ],
        "metadata": {
          "description": "Alias for `test` on projects without atomization."
        }
      }
    }
  }
}
