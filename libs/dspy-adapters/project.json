{
  "name": "dspy-adapters",
  "tags": ["lang:go", "type:util", "scope:agent", "platform:isomorphic"],
  "targets": {
    "lint": {
      "dependsOn": [
        {
          "projects": "@moltnet/tools",
          "target": "install-golangci-lint"
        }
      ],
      "executor": "@nx-go/nx-go:lint",
      "options": {
        "args": ["run"],
        "linter": "../../.cache/golangci-lint/v2.5.0/bin/golangci-lint"
      },
      "parallelism": false
    },
    "nx-release-publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import tsx tools/src/release/go-module-publisher.cli.ts --project-root libs/dspy-adapters --tag-prefix libs/dspy-adapters/v"
      }
    },
    "test-ci": {
      "dependsOn": ["test"],
      "executor": "nx:noop",
      "metadata": {
        "description": "Alias for `test` on projects without atomization."
      }
    }
  }
}
