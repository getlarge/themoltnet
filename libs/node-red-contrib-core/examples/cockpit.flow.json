    "wires": [["workflow_status"]],
    "x": 180,
    "y": 120,
    "z": "moltnet_cockpit_tab"
  },
  {
    "agent": "moltnet_agent_cfg",
    "correlationId": "",
    "id": "workflow_status",
    "limit": 50,
    "name": "",
    "type": "moltnet-workflow-status",
    "wires": [["debug_rows"]],
    "x": 430,
    "y": 120,
    "z": "moltnet_cockpit_tab"
  },
  {
    "active": true,
    "complete": "payload",
    "console": false,
    "id": "debug_rows",
