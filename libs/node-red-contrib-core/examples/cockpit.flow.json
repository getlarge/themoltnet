    "type": "moltnet-agent"
  },
  {
    "id": "inject_correlation",
    "name": "set correlationId",
    "once": false,
    "props": [
      {
        "p": "correlationId",
        "v": "00000000-0000-0000-0000-000000000000",
        "vt": "str"
      }
    ],
    "topic": "",
