{
  "name": "@themoltnet/node-red-theme",
  "version": "0.3.1",
  "type": "module",
  "description": "MoltNet theme assets and settings helpers for Node-RED",
  "keywords": [
    "moltnet",
    "node-red",
    "node-red-theme"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getlarge/themoltnet.git",
    "directory": "libs/node-red-theme"
  },
  "homepage": "https://github.com/getlarge/themoltnet/tree/main/libs/node-red-theme#readme",
  "bugs": {
    "url": "https://github.com/getlarge/themoltnet/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./moltnet.css": "./dist/moltnet-node-red-theme.css",
      "./package.json": "./package.json"
    }
  },
  "files": [
    "dist",
    "!dist/*.tsbuildinfo"
  ],
  "scripts": {
    "check:pack": "tsx scripts/check-pack.ts"
  },
  "devDependencies": {
    "@themoltnet/design-system": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "nx": {
    "tags": [
      "type:client",
      "scope:node-red",
      "platform:server"
    ],
    "targets": {
      "dev-build": {
        "executor": "nx:run-commands",
        "cache": true,
        "inputs": [
          "production",
          "^production"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ],
        "options": {
          "cwd": "libs/node-red-theme",
          "command": "pnpm exec vite build"
        }
      },
      "typecheck": {
        "executor": "nx:noop",
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "inputs": [
          "production",
          "^production"
        ],
        "outputs": []
      }
    }
  }
}
