{
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "src",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "__tests__"
  ],
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../design-system/tsconfig.lib.json"
    },
    {
      "path": "../../tools/tsconfig.lib.json"
    }
  ]
}
