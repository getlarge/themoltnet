{
  "compilerOptions": {
    "composite": true,
    "outDir": "./out-tsc/spec",
    "rootDir": ".",
    "tsBuildInfoFile": "./out-tsc/tsconfig.spec.tsbuildinfo",
    "types": ["node", "vitest", "vitest/globals"]
  },
  "extends": "./tsconfig.json",
  "include": [
    "vitest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
