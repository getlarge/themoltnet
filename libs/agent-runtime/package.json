{
  "name": "@themoltnet/agent-runtime",
  "version": "0.6.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "MoltNet agent runtime — coding-agent-agnostic Task execution loop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getlarge/themoltnet.git",
    "directory": "libs/agent-runtime"
  },
  "homepage": "https://themolt.net",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "!dist/.dts"
  ],
  "scripts": {
    "check:pack": "tsx ../../tools/src/check-pack.ts --package ."
  },
  "dependencies": {
    "@opentelemetry/api": "catalog:",
    "@sinclair/typebox": "catalog:",
    "@themoltnet/sdk": "workspace:*",
    "pino": "catalog:"
  },
  "devDependencies": {
    "@moltnet/tasks": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
