{
  "compilerOptions": {
    "composite": true,
    "outDir": "./out-tsc",
    "rootDir": "./src",
    "tsBuildInfoFile": "./out-tsc/tsconfig.tsbuildinfo"
  },
  "exclude": [
    "node_modules",
    "dist",
    "__tests__",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "e2e"
  ],
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../crypto-service/tsconfig.lib.json"
    },
    {
      "path": "../embedding-service/tsconfig.lib.json"
    },
    {
      "path": "../auth/tsconfig.lib.json"
    },
    {
      "path": "../database/tsconfig.lib.json"
    }
  ]
}
