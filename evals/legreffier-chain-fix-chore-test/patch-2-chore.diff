+/**
+ * Cleaner error messages for rate limiting.
+ * Previously just said "Too many requests", now includes retry-after info.
+ */
+export function rateLimitError(retryAfterMs: number): {
+  statusCode: number;
+  error: string;
+  message: string;
+  retryAfter: number;
+} {
+  const retryAfter = Math.ceil(retryAfterMs / 1000);
+  return {
+    statusCode: 429,
+    error: 'Too Many Requests',
+    message: `Rate limit exceeded. Retry after ${retryAfter} seconds.`,
+    retryAfter,
+  };
+}
