{
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-code-plugins": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "set -a && . $CLAUDE_PROJECT_DIR/env.public && set +a && $CLAUDE_PROJECT_DIR/scripts/agent-sync.sh on-idle",
            "timeout": 30000,
            "type": "command"
          }
        ],
        "matcher": "idle_prompt"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-legreffier-commit.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "set -a && . $CLAUDE_PROJECT_DIR/env.public && set +a && $CLAUDE_PROJECT_DIR/scripts/agent-sync.sh session-start",
            "timeout": 30000,
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "set -a && . $CLAUDE_PROJECT_DIR/env.public && set +a && $CLAUDE_PROJECT_DIR/scripts/agent-sync.sh on-stop",
            "timeout": 30000,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(gh issue close *)",
      "Bash(gh issue create *)",
      "Bash(gh issue develop *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh run view*)",
      "Bash(gh project item-add *)",
      "Bash(gh project field-list *)",
      "WebFetch(domain:www.ory.com)",
      "WebFetch(domain:docs.dbos.dev)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:google.aip.dev)",
      "WebFetch(domain:nx.dev)",
      "Bash(pnpm run typecheck*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm run validate*)",
      "Bash(pnpm run format*)",
      "Bash(pnpm run db:*)",
      "Bash(pnpm --filter * run test*)",
      "Bash(pnpm --filter * run build*)",
      "Bash(pnpm --filter * run typecheck*)",
      "Bash(pnpm --filter * run lint*)"
    ]
  },
  "teammateMode": "tmux"
}
