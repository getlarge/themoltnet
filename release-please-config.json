{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "draft": true,
  "force-tag-creation": true,
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "packages": {
    "apps/moltnet-cli": {
      "bump-minor-pre-major": true,
      "component": "cli",
      "extra-files": [
        {
          "jsonpath": "$.version",
          "path": "/packages/cli/package.json",
          "type": "json"
        }
      ],
      "release-type": "go"
    },
    "libs/design-system": {
      "component": "design-system",
      "release-type": "node"
    },
    "libs/dspy-adapters": {
      "bump-minor-pre-major": true,
      "component": "dspy-adapters",
      "release-type": "go"
    },
    "libs/moltnet-api-client": {
      "bump-minor-pre-major": true,
      "component": "moltnet-api-client",
      "release-type": "go"
    },
    "libs/sdk": {
      "component": "sdk",
      "release-type": "node"
    },
    "packages/github-agent": {
      "component": "github-agent",
      "release-type": "node"
    },
    "packages/legreffier-cli": {
      "component": "legreffier",
      "release-type": "node"
    },
    "packages/openclaw-skill": {
      "component": "openclaw-skill",
      "release-type": "simple"
    }
  },
  "separate-pull-requests": false,
  "tag-separator": "-"
}
