{
  "name": "@moltnet/tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI tools for MoltNet operations (bootstrap, admin, etc.)",
  "scripts": {
    "bootstrap": "tsx src/bootstrap-genesis-agents.ts",
    "check-secrets": "tsx src/check-secrets.ts",
    "check-quickstart": "node --import tsx src/check-quickstart-drift.ts",
    "download-model": "node download-embedding-model.mjs",
    "gpack": "tsx ../libs/context-evals/src/pipeline.ts",
    "compile-pack": "tsx src/compile-pack.ts",
    "graph:provenance": "tsx src/export-pack-provenance.ts",
    "seed-feed": "tsx src/seed-public-feed.ts",
    "eval:setup": "tsx src/skill-evals/eval-setup.ts",
    "eval:teardown": "tsx src/skill-evals/eval-setup.ts --teardown",
    "gpack:skill-eval": "tsx src/skill-evals/skill-eval-pipeline.ts",
    "mirror:experiment": "tsx src/mirror-experiment/experiment.ts",
    "mirror:gepa-smoke": "tsx src/mirror-experiment/gepa-smoke-test.ts",
    "typecheck": "tsc -b --emitDeclarationOnly",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ax-llm/ax": "catalog:",
    "@dotenvx/dotenvx": "catalog:",
    "@huggingface/transformers": "catalog:",
    "drizzle-orm": "catalog:",
    "@moltnet/bootstrap": "workspace:*",
    "@moltnet/context-evals": "workspace:*",
    "@moltnet/crypto-service": "workspace:*",
    "@moltnet/database": "workspace:*",
    "@moltnet/mcp-server": "workspace:*",
    "@moltnet/models": "workspace:*",
    "@moltnet/rest-api": "workspace:*",
    "@sinclair/typebox": "catalog:",
    "@themoltnet/github-agent": "workspace:*",
    "@themoltnet/sdk": "workspace:*",
    "fastq": "catalog:",
    "smol-toml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
