{
  "name": "@moltnet/tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI tools for MoltNet operations (bootstrap, admin, etc.)",
  "generators": "./generators.json",
  "scripts": {
    "bootstrap": "tsx src/bootstrap-genesis-agents.ts",
    "check-secrets": "tsx src/check-secrets.ts",
    "check-quickstart": "node --import tsx src/check-quickstart-drift.ts",
    "download-model": "node download-embedding-model.mjs",
    "eval:setup": "tsx src/eval-setup.ts",
    "eval:teardown": "tsx src/eval-setup.ts --teardown",
    "task:bootstrap-local": "tsx src/tasks/bootstrap-local-agent.ts",
    "bench:ory": "tsx src/bench-ory-connection-reuse.ts",
    "bench:embedding": "tsx src/bench-embedding-warmup.ts",
    "smtp:test": "tsx src/test-smtp.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "catalog:",
    "@earendil-works/pi-ai": "catalog:",
    "@earendil-works/pi-coding-agent": "catalog:",
    "@huggingface/transformers": "catalog:",
    "@moltnet/auth": "workspace:*",
    "@moltnet/bootstrap": "workspace:*",
    "@moltnet/crypto-service": "workspace:*",
    "@moltnet/database": "workspace:*",
    "@moltnet/discovery": "workspace:*",
    "@moltnet/embedding-service": "workspace:*",
    "@moltnet/mcp-server": "workspace:*",
    "@moltnet/models": "workspace:*",
    "@moltnet/rest-api": "workspace:*",
    "@moltnet/tasks": "workspace:*",
    "@ory/client-fetch": "catalog:",
    "@themoltnet/agent-runtime": "workspace:*",
    "@themoltnet/github-agent": "workspace:*",
    "@themoltnet/pi-extension": "workspace:*",
    "@themoltnet/sdk": "workspace:*",
    "@zip.js/zip.js": "catalog:",
    "drizzle-orm": "catalog:",
    "fastq": "catalog:",
    "figlet": "catalog:",
    "smol-toml": "catalog:",
    "tar": "catalog:",
    "typebox": "catalog:",
    "undici": "catalog:"
  },
  "devDependencies": {
    "@nx/devkit": "catalog:",
    "@types/figlet": "^1.7.0",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "nx": {
    "tags": [
      "type:tool",
      "scope:tooling",
      "platform:cli"
    ],
    "targets": {
      "install-golangci-lint": {
        "cache": true,
        "executor": "nx:run-commands",
        "inputs": [
          "{workspaceRoot}/tools/package.json",
          {
            "runtime": "go version"
          }
        ],
        "options": {
          "command": "GOBIN=\"$PWD/.cache/golangci-lint/v2.5.0/bin\" go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.5.0",
          "cwd": "{workspaceRoot}"
        },
        "outputs": [
          "{workspaceRoot}/.cache/golangci-lint/v2.5.0/bin"
        ]
      }
    }
  }
}
