# Required
ANTHROPIC_API_KEY=sk-ant-...

# MoltNet credentials (pack fetching). Use an existing .moltnet/<agent>/moltnet.json
# from the parent monorepo, or set these env vars directly and run
# `npx moltnet config init-from-env` in this directory.
MOLTNET_CREDENTIALS=../../.moltnet/legreffier/moltnet.json
MOLTNET_DIARY_ID=6e4d9948-8ec5-4f59-b82a-3acbc4bbc396
MOLTNET_RENDERED_PACK_ID=6e1e24d4-4a80-41bd-8a04-736c0c902794

# Optional — model overrides. Defaults: opus-4-7 for both.
# To match the Go CLI's claude agent defaults:
#   AGENT_MODEL=claude-sonnet-4-6
AGENT_MODEL=claude-opus-4-7
JUDGE_MODEL=claude-opus-4-7

# Optional — comma-separated list of scenarios to run (defaults to all three headliners).
SCENARIOS=auth-middleware-early-return,repository-tenant-scope-bypass,e2e-raw-fetch-vs-api-client
