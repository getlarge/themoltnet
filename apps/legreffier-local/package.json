    "@sinclair/typebox": "catalog:",
    "@themoltnet/sdk": "workspace:*",
    "fastify": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
