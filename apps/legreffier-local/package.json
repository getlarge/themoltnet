{
  "name": "@moltnet/legreffier-local",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local MCP server wrapping AxLearn with diary-backed self-improvement",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
