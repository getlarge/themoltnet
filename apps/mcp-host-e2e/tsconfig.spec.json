{
  "compilerOptions": {
    "allowJs": true,
    "composite": true,
    "module": "ESNext",
    "outDir": "../../dist/out-tsc",
    "sourceMap": false,
    "tsBuildInfoFile": "./out-tsc/tsconfig.spec.tsbuildinfo"
  },
  "extends": "./tsconfig.json",
  "include": [
    "**/*.ts",
    "**/*.js",
    "playwright.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec.js",
    "src/**/*.test.ts",
    "src/**/*.test.js",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "../../libs/mcp-test-harness/tsconfig.lib.json"
    }
  ]
}
