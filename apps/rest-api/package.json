{
  "name": "@moltnet/rest-api",
  "version": "0.6.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -b --emitDeclarationOnly && tsc -b tsconfig.test.json --force"
  },
  "dependencies": {
    "@fastify/cors": "catalog:",
    "@fastify/helmet": "catalog:",
    "@fastify/otel": "catalog:",
    "@fastify/rate-limit": "catalog:",
    "@fastify/swagger": "catalog:",
    "@scalar/fastify-api-reference": "catalog:",
    "@fastify/type-provider-typebox": "catalog:",
    "@moltnet/auth": "workspace:*",
    "@moltnet/crypto-service": "workspace:*",
    "@moltnet/database": "workspace:*",
    "@moltnet/tasks": "workspace:*",
    "multiformats": "catalog:",
    "@moltnet/discovery": "workspace:*",
    "@huggingface/transformers": "catalog:",
    "@moltnet/context-distill": "workspace:*",
    "@moltnet/context-pack-service": "workspace:*",
    "@moltnet/diary-service": "workspace:*",
    "@moltnet/task-service": "workspace:*",
    "@moltnet/embedding-service": "workspace:*",
    "@moltnet/models": "workspace:*",
    "@moltnet/observability": "workspace:*",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/exporter-logs-otlp-proto": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-proto": "catalog:",
    "@opentelemetry/exporter-trace-otlp-proto": "catalog:",
    "@opentelemetry/instrumentation": "catalog:",
    "@opentelemetry/instrumentation-dns": "catalog:",
    "@opentelemetry/instrumentation-http": "catalog:",
    "@opentelemetry/instrumentation-net": "catalog:",
    "@opentelemetry/instrumentation-pg": "catalog:",
    "@opentelemetry/instrumentation-pino": "catalog:",
    "@opentelemetry/instrumentation-runtime-node": "catalog:",
    "@opentelemetry/instrumentation-undici": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "@ory/client-fetch": "catalog:",
    "@sinclair/typebox": "catalog:",
    "drizzle-orm": "catalog:",
    "fastify": "catalog:",
    "fastify-plugin": "catalog:",
    "pino": "catalog:",
    "pino-opentelemetry-transport": "catalog:",
    "pino-pretty": "catalog:",
    "thread-stream": "catalog:",
    "winston": "catalog:",
    "winston-transport": "catalog:"
  },
  "devDependencies": {
    "@moltnet/api-client": "workspace:*",
    "@moltnet/bootstrap": "workspace:*",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "nx": {
    "tags": [
      "type:app",
      "scope:public",
      "platform:server"
    ],
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist/main.js",
          "{projectRoot}/dist/openapi.json"
        ]
      },
      "build:migrate": {
        "cache": true,
        "dependsOn": [
          "build"
        ],
        "executor": "nx:run-commands",
        "inputs": [
          "production",
          "^production"
        ],
        "options": {
          "command": "vite build --ssr src/migrate.ts --outDir dist --emptyOutDir false",
          "cwd": "apps/rest-api"
        },
        "outputs": [
          "{projectRoot}/dist/migrate.js"
        ]
      },
      "docker:build": {
        "dependsOn": [
          "build:migrate"
        ]
      },
      "e2e": {
        "cache": true,
        "executor": "nx:run-commands",
        "inputs": [
          "default",
          "^production",
          "{projectRoot}/vitest.config.e2e.ts",
          "{projectRoot}/e2e/**/*",
          {
            "externalDependencies": [
              "vitest"
            ]
          }
        ],
        "options": {
          "command": "vitest run --config vitest.config.e2e.ts",
          "cwd": "apps/rest-api"
        },
        "outputs": []
      }
    }
  }
}
