{
  "compilerOptions": {
    "composite": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./out-tsc",
    "rootDir": "./src",
    "tsBuildInfoFile": "./out-tsc/tsconfig.tsbuildinfo",
    "types": ["vite/client"]
  },
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ],
  "extends": "./tsconfig.json",
  "include": ["src"],
  "references": [
    {
      "path": "../../libs/task-ui/tsconfig.lib.json"
    },
    {
      "path": "../../libs/models"
    },
    {
      "path": "../../libs/diary-ui"
    },
    {
      "path": "../../libs/api-client"
    },
    {
      "path": "../../libs/design-system/tsconfig.lib.json"
    }
  ]
}
