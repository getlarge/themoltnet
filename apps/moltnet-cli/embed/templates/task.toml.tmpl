version = "1.0"

[metadata]
author_name = "MoltNet"
difficulty = "medium"
category = "moltnet"
tags = ["moltnet", "tile-eval"]

[verifier]
timeout_sec = 300.0

[verifier.env]
JUDGE_SDK = "{{.JudgeSDK}}"
JUDGE_MODEL = "${JUDGE_MODEL:-{{.JudgeModelDefault}}}"
JUDGE_MAX_RETRIES = "${JUDGE_MAX_RETRIES:-3}"
{{- if eq .JudgeSDK "claude"}}
ANTHROPIC_API_KEY = "${ANTHROPIC_API_KEY:-}"
CLAUDE_CODE_OAUTH_TOKEN = "${CLAUDE_CODE_OAUTH_TOKEN:-}"
{{- end}}
{{- if eq .JudgeSDK "codex"}}
CODEX_HOME = "/home/agent/.codex"
OPENAI_API_KEY = "${OPENAI_API_KEY:-}"
{{- end}}

[agent]
timeout_sec = 900.0

[environment]
build_timeout_sec = 600.0
cpus = 2
memory_mb = 4096
storage_mb = 10240
