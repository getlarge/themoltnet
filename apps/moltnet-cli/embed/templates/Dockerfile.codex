FROM docker/sandbox-templates:codex

USER root

# System packages (rarely changes)
RUN apt-get update && apt-get install -y jq && rm -rf /var/lib/apt/lists/*

# Pre-install judge with both SDK dependencies (claude + codex).
# test.sh selects which judge script to run at runtime.
COPY judge/ /opt/judge/
RUN cd /opt/judge && npm install --ignore-scripts

# Keep Codex sandbox non-interactive for eval runs.
RUN mkdir -p /home/agent/.codex && \
    chown -R agent:agent /home/agent/.codex

# Docker Desktop macOS VM fails TLS 1.3 handshakes with Cloudflare edge IPs
# (api.anthropic.com). Force TLS 1.2 max for Node.js (judge only on Codex image).
ENV NODE_OPTIONS="--tls-max-v1.2"

USER agent

WORKDIR /app
