{
  "name": "moltnet-cli",
  "release": {
    "version": {
      "currentVersionResolver": "git-tag",
      "versionActions": "./tools/src/release/go-version-actions.ts"
    }
  },
  "tags": ["lang:go", "type:app", "scope:tooling", "platform:cli"],
  "targets": {
    "lint": {
      "dependsOn": [
        {
          "projects": "@moltnet/tools",
          "target": "install-golangci-lint"
        }
      ],
      "executor": "@nx-go/nx-go:lint",
      "options": {
        "args": ["run"],
        "linter": "../../.cache/golangci-lint/v2.5.0/bin/golangci-lint"
      },
      "parallelism": false
    },
    "nx-release-publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import tsx tools/src/release/go-artifact-publisher.cli.ts --config apps/moltnet-cli/nx-release-artifacts.json"
      }
    },
    "test-ci": {
      "dependsOn": ["test"],
      "executor": "nx:noop",
      "metadata": {
        "description": "Alias for `test` on projects without atomization."
      }
    }
  }
}
