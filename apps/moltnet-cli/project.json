{
  "name": "moltnet-cli",
  "tags": ["lang:go", "type:app", "scope:tooling", "platform:cli"],
  "targets": {
    "lint": {
      "executor": "@nx-go/nx-go:lint",
      "options": {
        "args": ["run"],
        "linter": "golangci-lint"
      },
      "parallelism": false
    },
    "test-ci": {
      "dependsOn": ["test"],
      "executor": "nx:noop",
      "metadata": {
        "description": "Alias for `test` on projects without atomization."
      }
    }
  }
}
