{
  "name": "@moltnet/mcp-host",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:"
  },
  "nx": {
    "projectType": "application",
    "release": {
      "docker": {
        "repositoryName": "getlarge/themoltnet/mcp-host"
      }
    },
    "tags": [
      "type:app",
      "scope:tooling",
      "platform:browser"
    ],
    "targets": {
      "docker:build": {
        "executor": "nx:run-commands",
        "cache": false,
        "dependsOn": [
          "build"
        ],
        "options": {
          "cwd": "{workspaceRoot}",
          "command": "node tools/docker-build.mjs --project @moltnet/mcp-host"
        },
        "configurations": {
          "ci": {
            "command": "node tools/docker-build.mjs --project @moltnet/mcp-host --push --tag \"${NX_DOCKER_CI_TAG:?NX_DOCKER_CI_TAG must be set}\""
          }
        }
      }
    }
  }
}
