{
  "name": "@moltnet/mcp-server",
  "version": "0.6.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "tsx watch src/main.ts",
    "seed:task-app": "tsx e2e/seed-task-app.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -b --emitDeclarationOnly && tsc -b tsconfig.test.json --force"
  },
  "dependencies": {
    "@moltnet/api-client": "workspace:*",
    "@moltnet/observability": "workspace:*",
    "@moltnet/models": "workspace:*",
    "@moltnet/crypto-service": "workspace:*",
    "@moltnet/entry-explore-mcp-app": "workspace:*",
    "@moltnet/mcp-auth-proxy": "workspace:*",
    "@moltnet/task-mcp-app": "workspace:*",
    "@moltnet/tasks": "workspace:*",
    "@themoltnet/design-system": "workspace:*",
    "@getlarge/fastify-mcp": "catalog:",
    "@fastify/otel": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-proto": "catalog:",
    "@opentelemetry/exporter-trace-otlp-proto": "catalog:",
    "@opentelemetry/instrumentation": "catalog:",
    "@opentelemetry/instrumentation-dns": "catalog:",
    "@opentelemetry/instrumentation-http": "catalog:",
    "@opentelemetry/instrumentation-net": "catalog:",
    "@opentelemetry/instrumentation-pino": "catalog:",
    "@opentelemetry/instrumentation-pg": "catalog:",
    "@opentelemetry/instrumentation-runtime-node": "catalog:",
    "@opentelemetry/instrumentation-undici": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "typebox": "catalog:",
    "fastify": "catalog:",
    "fastify-plugin": "catalog:",
    "pino": "catalog:",
    "pino-opentelemetry-transport": "catalog:",
    "thread-stream": "catalog:"
  },
  "devDependencies": {
    "@moltnet/bootstrap": "workspace:*",
    "@moltnet/database": "workspace:*",
    "@moltnet/mcp-test-harness": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "drizzle-orm": "catalog:",
    "pino-pretty": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "tsx": "catalog:",
    "vite": "catalog:"
  },
  "nx": {
    "tags": [
      "type:app",
      "scope:public",
      "platform:server"
    ],
    "targets": {
      "dev": {
        "dependsOn": [
          "build-deps"
        ]
      },
      "e2e": {
        "cache": true,
        "executor": "nx:run-commands",
        "inputs": [
          "default",
          "^production",
          "{projectRoot}/vitest.config.e2e.ts",
          "{projectRoot}/e2e/**/*",
          {
            "externalDependencies": [
              "vitest"
            ]
          }
        ],
        "options": {
          "command": "vitest run --config vitest.config.e2e.ts",
          "cwd": "apps/mcp-server"
        },
        "outputs": []
      }
    }
  }
}
