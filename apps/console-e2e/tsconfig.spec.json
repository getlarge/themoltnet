{
  "compilerOptions": {
    "allowJs": true,
    "composite": true,
    "module": "ESNext",
    "outDir": "./out-tsc/spec",
    "sourceMap": false,
    "tsBuildInfoFile": "./out-tsc/tsconfig.spec.tsbuildinfo",
    "types": ["node", "@playwright/test"]
  },
  "extends": "./tsconfig.json",
  "include": [
    "playwright.config.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.d.ts"
