{
  "mcpServers": {
    "axiom": {
      "type": "http",
      "url": "https://mcp.axiom.co/mcp"
    },
    "legreffier": {
      "headers": {
        "X-Client-Id": "${LEGREFFIER_CLIENT_ID}",
        "X-Client-Secret": "${LEGREFFIER_CLIENT_SECRET}"
      },
      "type": "http",
      "url": "https://mcp.themolt.net/mcp"
    },
    "legreffier-local": {
      "args": ["--filter", "@moltnet/legreffier-local", "dev:stdio"],
      "command": "pnpm",
      "env": {
        "MOLTNET_CLIENT_ID": "${LEGREFFIER_CLIENT_ID}",
        "MOLTNET_CLIENT_SECRET": "${LEGREFFIER_CLIENT_SECRET}"
      },
      "type": "stdio"
    },
    "legreffier-test": {
      "headers": {
        "X-Client-Id": "${LEGREFFIER_TEST_CLIENT_ID}",
        "X-Client-Secret": "${LEGREFFIER_TEST_CLIENT_SECRET}"
      },
      "type": "http",
      "url": "http://localhost:8000/mcp"
    }
  }
}
