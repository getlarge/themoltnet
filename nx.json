{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "generators": {
    "@nx/web:application": {
      "e2eTestRunner": "playwright",
      "linter": "eslint",
      "style": "css",
      "unitTestRunner": "vitest"
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "docker": [
      "{projectRoot}/Dockerfile",
      "{projectRoot}/Dockerfile.*",
      "{projectRoot}/.dockerignore",
      { "dependentTasksOutputFiles": "**/dist/**/*", "transitive": true },
      { "runtime": "docker --version" },
      { "externalDependencies": ["@nx/docker"] }
    ],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)",
      "!{projectRoot}/__tests__/**/*",
      "!{projectRoot}/**/*.{md,mdx}",
      "!{projectRoot}/tsconfig.test.json",
      "!{projectRoot}/vitest.config.*",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/src/test-setup.[jt]s"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/pnpm-workspace.yaml",
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/.npmrc",
      "{workspaceRoot}/nx.json"
    ]
  },
  "plugins": [
    {
      "options": {
        "extensions": ["ts", "tsx"],
        "targetName": "lint"
      },
      "plugin": "@nx/eslint/plugin"
    },
    {
      "options": {
        "buildDepsTargetName": "build-deps",
        "buildTargetName": "build",
        "devTargetName": "dev",
        "previewTargetName": "preview",
        "serveStaticTargetName": "serve-static",
        "serveTargetName": "serve",
        "testTargetName": "vite-test-disabled",
        "typecheckTargetName": "vite-typecheck-disabled",
        "watchDepsTargetName": "watch-deps"
      },
      "plugin": "@nx/vite/plugin"
    },
    {
      "options": {
        "ciTargetName": "test-ci",
        "testMode": "run",
        "testTargetName": "test"
      },
      "plugin": "@nx/vitest"
    },
    {
      "options": {
        "targetName": "e2e"
      },
      "plugin": "@nx/playwright/plugin"
    },
    {
      "options": {
        "buildTarget": {
          "name": "docker:build"
        },
        "runTarget": {
          "name": "docker:run"
        }
      },
      "plugin": "@nx/docker"
    },
    {
      "options": {
        "build": {
          "configName": "tsconfig.lib.json",
          "targetName": "build"
        },
        "typecheck": {
          "targetName": "typecheck"
        }
      },
      "plugin": "@nx/js/typescript"
    },
    "@nx-go/nx-go"
  ],
  "sync": {
    "applyChanges": true
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build", "^typecheck"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"]
    },
    "docker:build": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": ["docker", "^production"]
    },
    "lint": {
      "cache": true,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/eslint.config.mjs",
        "{workspaceRoot}/.golangci.yml",
        "{projectRoot}/.golangci.yml"
      ]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "typecheck": {
      "cache": true,
      "inputs": ["default", "^production"],
      "outputs": ["{projectRoot}/out-tsc"]
    }
  }
}
