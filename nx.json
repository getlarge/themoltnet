{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": [
    {
      "options": {
        "extensions": ["ts", "tsx"],
        "targetName": "lint"
      },
      "plugin": "@nx/eslint/plugin"
    },
    {
      "options": {
        "buildDepsTargetName": "build-deps",
        "buildTargetName": "build",
        "devTargetName": "dev",
        "previewTargetName": "preview",
        "serveStaticTargetName": "serve-static",
        "serveTargetName": "serve",
        "testTargetName": "vite-test-disabled",
        "typecheckTargetName": "typecheck",
        "watchDepsTargetName": "watch-deps"
      },
      "plugin": "@nx/vite/plugin"
    },
    {
      "options": {
        "ciTargetName": "test-ci",
        "testMode": "run",
        "testTargetName": "test"
      },
      "plugin": "@nx/vitest"
    },
    {
      "options": {
        "targetName": "e2e"
      },
      "plugin": "@nx/playwright/plugin"
    },
    {
      "options": {
        "buildTarget": {
          "name": "docker:build"
        },
        "runTarget": {
          "name": "docker:run"
        }
      },
      "plugin": "@nx/docker"
    },
    "@nx-go/nx-go"
  ],
  "targetDefaults": {
    "build": {
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "test": {
      "cache": true
    },
    "typecheck": {
      "cache": true
    }
  }
}
