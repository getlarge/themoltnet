{
  "name": "moltnet",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Infrastructure for AI agent autonomy",
  "repository": {
    "type": "git",
    "url": "https://github.com/getlarge/moltnet"
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc",
  "scripts": {
    "claude": "npx @themoltnet/cli start claude",
    "codex": "npx @themoltnet/cli start codex",
    "pi": "npx @themoltnet/cli start pi",
    "build": "nx run-many -t build",
    "build:cli": "go build -o dist/moltnet ./apps/moltnet-cli",
    "go:build": "go build -o dist/moltnet ./apps/moltnet-cli",
    "go:test": "go test github.com/getlarge/themoltnet/apps/moltnet-cli/... && go test github.com/getlarge/themoltnet/libs/moltnet-api-client/... && go test github.com/getlarge/themoltnet/libs/dspy-adapters/...",
    "go:vet": "go vet github.com/getlarge/themoltnet/apps/moltnet-cli/... && go vet github.com/getlarge/themoltnet/libs/moltnet-api-client/... && go vet github.com/getlarge/themoltnet/libs/dspy-adapters/...",
    "go:fmt": "gofmt -w apps/moltnet-cli/ libs/moltnet-api-client/ libs/dspy-adapters/",
    "go:fmt:check": "test -z \"$(gofmt -l apps/moltnet-cli/ libs/moltnet-api-client/ libs/dspy-adapters/)\"",
    "go:lint": "pnpm run go:vet",
    "go:generate": "go generate ./libs/moltnet-api-client/...",
    "postinstall": "update-ts-references",
    "dev:mcp": "npx dotenvx run --env-file .env.local -- pnpm --filter @moltnet/mcp-server dev",
    "dev:api": "npx dotenvx run --env-file .env.local -- pnpm --filter @moltnet/rest-api dev",
    "dev:landing": "npx dotenvx run --env-file .env.local -- pnpm --filter @moltnet/landing dev",
    "dev:console": "npx dotenvx run --env-file .env.local -- pnpm --filter @moltnet/console dev",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "db:generate": "pnpm --filter @moltnet/database generate",
    "db:migrate": "pnpm --filter @moltnet/database migrate",
    "db:migrate:run": "pnpm --filter @moltnet/database db:migrate:run",
    "db:push": "pnpm --filter @moltnet/database push",
    "db:status": "pnpm --filter @moltnet/database db:status",
    "db:studio": "pnpm --filter @moltnet/database studio",
    "clean": "find . -name '*.tsbuildinfo' -not -path '*/node_modules/*' -not -path '*/.worktrees/*' -not -path '*/.claude/*' -delete && find . -path '*/dist' -not -path '*/node_modules/*' -not -path '*/.worktrees/*' -not -path '*/.claude/*' -prune -exec rm -rf {} +",
    "typecheck": "pnpm -r run typecheck",
    "typecheck:clean": "pnpm run clean && pnpm -r run typecheck",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "audit": "pnpm audit --prod",
    "generate:wordmark": "tsx tools/src/generate-wordmark.ts",
    "generate:openapi": "tsx apps/rest-api/scripts/generate-openapi.ts",
    "ory:backup": "node infra/ory/backup.mjs",
    "generate:client": "pnpm --filter @moltnet/api-client run generate",
    "generate": "pnpm run generate:openapi && pnpm run generate:client && prettier --write apps/rest-api/public/openapi.json libs/api-client/src/generated/",
    "check:pack": "tsx tools/src/check-pack.ts",
    "check:quickstart": "pnpm --filter @moltnet/tools run check-quickstart",
    "validate": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run check:pack && pnpm run check:quickstart",
    "docker:up": "docker compose --env-file .env.local up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "e2e:up": "COMPOSE_DISABLE_ENV_FILE=1 docker compose -f docker-compose.e2e.yaml up -d --build",
    "e2e:down": "COMPOSE_DISABLE_ENV_FILE=1 docker compose -f docker-compose.e2e.yaml down -v",
    "test:e2e": "pnpm -r --if-present run test:e2e",
    "bootstrap": "pnpm --filter @moltnet/tools bootstrap",
    "publish:skill": "packages/openclaw-skill/scripts/publish-clawhub.sh",
    "publish:skill:dry-run": "packages/openclaw-skill/scripts/publish-clawhub.sh --dry-run",
    "package:skill": "packages/openclaw-skill/scripts/package.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.go": [
      "gofmt -w"
    ]
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "catalog:",
    "@eslint/js": "catalog:",
    "@nx-go/nx-go": "catalog:",
    "@nx/docker": "catalog:",
    "@nx/eslint": "catalog:",
    "@nx/playwright": "catalog:",
    "@nx/vite": "catalog:",
    "@nx/vitest": "catalog:",
    "@nx/web": "catalog:",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-boundaries": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "husky": "catalog:",
    "jiti": "2.4.2",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "nx": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-sort-json": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "update-ts-references": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs"
    ],
    "overrides": {
      "minimatch": ">=10.2.5",
      "@isaacs/brace-expansion": ">=5.0.1",
      "brace-expansion@1": ">=1.1.13",
      "brace-expansion@2": ">=2.0.3",
      "brace-expansion": ">=5.0.5",
      "picomatch": ">=4.0.4",
      "flatted": ">=3.4.2",
      "lodash": ">=4.18.1",
      "path-to-regexp": ">=8.4.2",
      "handlebars": ">=4.7.9",
      "rollup": ">=4.59.0",
      "yaml": ">=2.8.3",
      "undici": ">=7.24.0",
      "defu": ">=6.1.5",
      "fastify": ">=5.8.3",
      "ajv@8": ">=8.18.0",
      "@anthropic-ai/sdk": ">=0.81.0",
      "bn.js": ">=4.12.3",
      "tar": ">=7.5.11",
      "hono": ">=4.12.7",
      "@hono/node-server": ">=1.19.10",
      "express-rate-limit": ">=8.2.2",
      "qs": ">=6.14.2",
      "smol-toml": ">=1.6.1"
    }
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
